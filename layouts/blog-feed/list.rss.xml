{{- printf "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <description>{{ with .Site.Params.description }}{{ . }}{{ end }}</description>
    <link>{{ .Site.BaseURL }}</link>
    <atom:link href="{{ printf "%sblog/feed/" .Site.BaseURL }}" rel="self" type="application/rss+xml" />
    <pubDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <generator>Hugo</generator>
    {{ range first 10 (where .Site.RegularPages "Section" "posts").ByDate.Reverse }}
    <item>
      <title>{{ .Title }}</title>
      <description>{{ .Content | htmlEscape | safeHTML }}</description>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <link>{{ .Permalink }}</link>
      <guid isPermaLink="true">{{ .Permalink }}</guid>
      {{ range .Params.tags }}<category>{{ . }}</category>{{ end }}
      {{ range .Params.categories }}<category>{{ . }}</category>{{ end }}
    </item>
    {{ end }}
  </channel>
</rss>
